{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": [
    "packages/cli/src/**/*.ts",
    "packages/cli/tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "packages/runtime-kit/templates"
  ]
}
